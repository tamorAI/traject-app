FROM oven/bun:1.2.21 AS builder
WORKDIR /app

RUN apt-get update -qq && apt-get install -y -qq git --no-install-recommends && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

COPY package.json bun.lock ./
COPY packages/ ./packages/
COPY apps/web/ ./apps/web/

RUN bash apps/web/scripts/start.sh next build

FROM oven/bun:1.2.21 AS runner
WORKDIR /app

RUN apt-get update -qq && apt-get install -y -qq git --no-install-recommends && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/package.json ./
COPY --from=builder /app/packages ./packages
COPY --from=builder /app/apps/web/.next ./apps/web/.next
COPY --from=builder /app/apps/web/public ./apps/web/public
COPY --from=builder /app/apps/web/package.json ./apps/web/package.json
COPY --from=builder /app/apps/web/next.config.ts ./apps/web/next.config.ts
COPY --from=builder /app/apps/web/scripts ./apps/web/scripts
COPY --from=builder /app/apps/web/.tamor-ui ./apps/web/.tamor-ui
COPY --from=builder /app/apps/web/node_modules ./apps/web/node_modules
COPY --from=builder /app/apps/web/tsconfig.json ./apps/web/tsconfig.json

ENV NODE_ENV=production
ENV PORT=3000

EXPOSE 3000

WORKDIR /app/apps/web

CMD ["bun", "run", "start"]
